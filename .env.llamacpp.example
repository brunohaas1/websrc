# Stack avançado (api + worker + scheduler + redis + postgres + llama.cpp)

# Core
LOG_LEVEL=INFO
LOG_JSON=1
ENVIRONMENT=production
SECRET_KEY=troque-esta-chave

# Role do processo: api | worker | scheduler
APP_ROLE=api
QUEUE_ENABLED=1

# Banco
DATABASE_URL=postgresql+psycopg://dashboard:dashboard@postgres:5432/dashboard

# Redis
REDIS_URL=redis://redis:6379/0

# Scheduler
SCRAPE_INTERVAL_MINUTES=30
DAILY_INTERVAL_HOURS=24
FEED_ENTRY_LIMIT=25

# Clima
WEATHER_CITY=Lajeado
WEATHER_STATE=Rio Grande do Sul
WEATHER_COUNTRY_CODE=BR
WEATHER_LAT=-29.4669
WEATHER_LON=-51.9614

# Segurança/API
API_RATE_LIMIT_DEFAULT=120/minute
API_RATE_LIMIT_RUN_NOW=6/minute
CACHE_TTL_SECONDS=90
CORS_ALLOWED_ORIGINS=https://seu-dominio.com

# IA local (llama.cpp)
AI_LOCAL_ENABLED=1
AI_LOCAL_BACKEND=llama_cpp
AI_LOCAL_URL=http://llamacpp:8080
AI_LOCAL_LLAMA_CPP_CHAT_ENDPOINT=/v1/chat/completions
AI_LOCAL_MODEL=llama-3.2-3b-instruct-q4_k_m
LLAMACPP_IMAGE=ghcr.io/ggml-org/llama.cpp:server
LLAMACPP_HOST_PORT=8081
LLAMACPP_GPU_LAYERS=35
AI_LOCAL_TIMEOUT_SECONDS=20
AI_LOCAL_RETRIES=1
AI_LOCAL_BACKOFF_MS=300
AI_LOCAL_CIRCUIT_FAIL_THRESHOLD=3
AI_LOCAL_CIRCUIT_OPEN_SECONDS=120
AI_LOCAL_ADAPTIVE_MIN_PER_RUN=3
AI_LOCAL_MAX_ENRICH_PER_RUN=10

# Alertas (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
