# Stack avançado (api + worker + scheduler + redis + postgres)

# Core
LOG_LEVEL=INFO
LOG_JSON=1
ENVIRONMENT=production
SECRET_KEY=troque-esta-chave

# Role do processo: api | worker
APP_ROLE=api
QUEUE_ENABLED=1

# Banco
DATABASE_URL=postgresql+psycopg://dashboard:dashboard@postgres:5432/dashboard

# Redis
REDIS_URL=redis://redis:6379/0

# Scheduler
SCRAPE_INTERVAL_MINUTES=30
DAILY_INTERVAL_HOURS=24
FEED_ENTRY_LIMIT=30

# Clima
WEATHER_CITY=Lajeado
WEATHER_STATE=Rio Grande do Sul
WEATHER_COUNTRY_CODE=BR
WEATHER_LAT=-29.4669
WEATHER_LON=-51.9614

# Segurança/API
API_RATE_LIMIT_DEFAULT=120/minute
API_RATE_LIMIT_RUN_NOW=6/minute
CACHE_TTL_SECONDS=90
CORS_ALLOWED_ORIGINS=https://seu-dominio.com

# IA local (Ollama)
AI_LOCAL_ENABLED=1
AI_LOCAL_BACKEND=ollama
AI_LOCAL_URL=http://ollama:11434
AI_LOCAL_LLAMA_CPP_CHAT_ENDPOINT=/v1/chat/completions
AI_LOCAL_MODEL=llama3.2:3b
AI_LOCAL_TIMEOUT_SECONDS=25
AI_LOCAL_RETRIES=2
AI_LOCAL_BACKOFF_MS=400
AI_LOCAL_CIRCUIT_FAIL_THRESHOLD=3
AI_LOCAL_CIRCUIT_OPEN_SECONDS=120
AI_LOCAL_ADAPTIVE_MIN_PER_RUN=5
AI_LOCAL_MAX_ENRICH_PER_RUN=16

# Alertas (opcional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
