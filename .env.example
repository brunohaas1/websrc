DATABASE_PATH=/app/data/dashboard.db
SCRAPE_INTERVAL_MINUTES=30
DAILY_INTERVAL_HOURS=24
FEED_ENTRY_LIMIT=30
WEATHER_CITY=Lajeado
WEATHER_STATE=Rio Grande do Sul
WEATHER_COUNTRY_CODE=BR
WEATHER_LAT=-29.4669
WEATHER_LON=-51.9614
LOG_LEVEL=INFO
LOG_JSON=1
SECRET_KEY=troque-esta-chave

CACHE_TTL_SECONDS=90
API_RATE_LIMIT_DEFAULT=120/minute
API_RATE_LIMIT_RUN_NOW=6/minute

# IA local (Ollama)
AI_LOCAL_ENABLED=0
AI_LOCAL_BACKEND=ollama
AI_LOCAL_URL=http://127.0.0.1:11434
AI_LOCAL_LLAMA_CPP_CHAT_ENDPOINT=/v1/chat/completions
AI_LOCAL_MODEL=qwen2.5:3b-instruct
AI_LOCAL_TIMEOUT_SECONDS=25
AI_LOCAL_RETRIES=2
AI_LOCAL_BACKOFF_MS=400
AI_LOCAL_CIRCUIT_FAIL_THRESHOLD=3
AI_LOCAL_CIRCUIT_OPEN_SECONDS=120
AI_LOCAL_ADAPTIVE_MIN_PER_RUN=4
AI_LOCAL_MAX_ENRICH_PER_RUN=12
