# ─── Core ──────────────────────────────────────────────
SECRET_KEY=          # random hex; auto-generated if empty
ADMIN_API_KEY=       # required for admin endpoints (X-Admin-Key header)
FINANCE_API_KEY=     # optional: protects finance write endpoints (X-Finance-Key header)
BRAPI_TOKEN=7ZG2YNFrjZLg2GtEzj8Hkv       # optional: token for https://brapi.dev stock quotes
LOG_LEVEL=INFO
LOG_JSON=1
APP_ROLE=all         # all | api | worker | scheduler

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://dashboard:changeme@postgres:5432/dashboard
DATABASE_PATH=/app/data/dashboard.db
POSTGRES_PASSWORD=changeme

# ─── Redis / Queue ─────────────────────────────────────
QUEUE_ENABLED=1
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=90

# ─── Scraping Schedule ─────────────────────────────────
SCRAPE_INTERVAL_MINUTES=30
DAILY_INTERVAL_HOURS=24
FEED_ENTRY_LIMIT=30
DATA_RETENTION_DAYS=90

# ─── Rate Limits ───────────────────────────────────────
API_RATE_LIMIT_DEFAULT=120/minute
API_RATE_LIMIT_RUN_NOW=6/minute

# ─── Weather ───────────────────────────────────────────
WEATHER_CITY=Lajeado
WEATHER_STATE=Rio Grande do Sul
WEATHER_COUNTRY_CODE=BR
WEATHER_LAT=-29.4669
WEATHER_LON=-51.9614

# ─── Local AI (llama.cpp) ──────────────────────────────
AI_LOCAL_ENABLED=1
AI_LOCAL_BACKEND=llama_cpp
AI_LOCAL_URL=http://llamacpp:8080
AI_LOCAL_LLAMA_CPP_CHAT_ENDPOINT=/v1/chat/completions
AI_LOCAL_MODEL=qwen2.5:7b-instruct
AI_LOCAL_TIMEOUT_SECONDS=30
AI_LOCAL_RETRIES=2
AI_LOCAL_BACKOFF_MS=400
AI_LOCAL_CIRCUIT_FAIL_THRESHOLD=3
AI_LOCAL_CIRCUIT_OPEN_SECONDS=120
AI_LOCAL_ADAPTIVE_MIN_PER_RUN=4
AI_LOCAL_MAX_ENRICH_PER_RUN=12

# ─── llama.cpp Docker ──────────────────────────────────
LLAMACPP_IMAGE=websrc-llamacpp:vulkan
LLAMACPP_MODEL=Qwen2.5-7B-Instruct-Q4_K_M.gguf
LLAMACPP_GPU_LAYERS=35
LLAMACPP_HOST_PORT=8081
LLAMACPP_DRI_RENDER=/dev/dri/renderD128
VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/radeon_icd.json

# ─── Currency Widget ──────────────────────────────────
CURRENCY_API_URL=https://economia.awesomeapi.com.br/json/last
CURRENCY_UPDATE_MINUTES=15

# ─── Service Monitor ──────────────────────────────────
SERVICE_MONITOR_INTERVAL_MINUTES=5

# ─── Web Push (VAPID) ─────────────────────────────────
# sGenerate keys: npx web-push generate-vapid-key
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@example.com

# ─── i18n / Locale ────────────────────────────────────
DEFAULT_LOCALE=pt-BR

# ─── PDF Export ────────────────────────────────────────
PDF_EXPORT_ENABLED=1
