:80 {
  encode gzip

  header {
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy strict-origin-when-cross-origin
    Permissions-Policy interest-cohort=()
    X-XSS-Protection "1; mode=block"
    Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
  }

  handle_path /static/* {
    root * /srv/static
    file_server {
      precompressed gzip
    }
    header Cache-Control "public, max-age=3600, must-revalidate"
    header ETag ""
  }

  @health path /health
  reverse_proxy @health ws-api:8000

  reverse_proxy ws-api:8000
}
